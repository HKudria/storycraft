# === Application ===
APP_ENV=dev
APP_SECRET=change-me-to-random-string
APP_FRONTEND_URL=http://localhost

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://storycraft:storycraft@postgres:5432/storycraft?serverVersion=16&charset=utf8

# === Redis ===
REDIS_URL=redis://redis:6379

# === JWT ===
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-me-to-random-string
JWT_TOKEN_TTL=900

# === Google OAuth2 ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Anthropic (Claude) ===
ANTHROPIC_API_KEY=your-anthropic-api-key

# === OpenAI (DALL-E) ===
OPENAI_API_KEY=your-openai-api-key

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_BASIC_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx

# === S3 / MinIO ===
S3_ENDPOINT=http://minio:9000
S3_KEY=minioadmin
S3_SECRET=minioadmin
S3_BUCKET=storycraft
S3_REGION=us-east-1

# === Messenger ===
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
