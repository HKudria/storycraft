<!DOCTYPE html>
<html>
<head>
<style>
    @page { margin: 12mm; }
    body { margin: 0; padding: 0; font-family: 'Georgia', 'Times New Roman', serif; color: #2d2d2d; }

    .cover {
        text-align: center;
        padding-top: 100px;
    }
    .cover-bar {
        width: 80px; height: 4px; background: #6366f1; margin: 0 auto 40px;
    }
    .cover h1 {
        font-size: 42px; color: #312e81; margin: 0 0 16px;
        line-height: 1.2;
    }
    .cover .subtitle {
        font-size: 18px; color: #818cf8; margin: 0 0 50px;
        font-style: italic;
    }
    .cover .meta {
        font-size: 14px; color: #9ca3af; margin: 6px 0;
    }

    .page { page-break-before: always; }

    .page-half-left {
        float: left;
        width: 48%;
        padding: 25mm 2% 0 0;
    }
    .page-half-right {
        float: right;
        width: 48%;
        padding: 25mm 0 0 2%;
    }

    .page-half-left img, .page-half-right img {
        width: 100%;
        border-radius: 8px;
    }

    .chapter-label {
        font-size: 12px;
        color: #a5b4fc;
        margin-bottom: 16px;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .story-text {
        font-size: 20px;
        line-height: 2;
        text-align: left;
        color: #374151;
    }

    .pagenum {
        text-align: center;
        font-size: 10px;
        color: #c4b5fd;
        padding-top: 5mm;
    }
</style>
</head>
<body>

<div class="cover">
    <div class="cover-bar"></div>
    <h1>{{ title }}</h1>
    <div class="subtitle">{{ storyForLabel }}</div>
    <div class="meta">{{ templateTitle }}</div>
    <div class="meta">{{ createdAt }}</div>
</div>

{% for page in pages %}
<div class="page">
    {% if loop.index is odd %}
    <div class="page-half-left">
        <div class="chapter-label">{{ chapterLabel }} {{ page.pageNumber }}</div>
        <div class="story-text">{{ page.text|nl2br }}</div>
    </div>
    {% if page.imagePath %}
    <div class="page-half-right">
        <img src="{{ page.imagePath }}" alt="Page {{ page.pageNumber }}">
    </div>
    {% endif %}
    {% else %}
    {% if page.imagePath %}
    <div class="page-half-left">
        <img src="{{ page.imagePath }}" alt="Page {{ page.pageNumber }}">
    </div>
    {% endif %}
    <div class="page-half-right">
        <div class="chapter-label">{{ chapterLabel }} {{ page.pageNumber }}</div>
        <div class="story-text">{{ page.text|nl2br }}</div>
    </div>
    {% endif %}
    <div style="clear: both"></div>
    <div class="pagenum">{{ page.pageNumber }}</div>
</div>
{% endfor %}

</body>
</html>
